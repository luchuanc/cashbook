NODE_ENV="postgre" # development | production

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cashbook?schema=public"

NUXT_APP_VERSION="4.3.13"
NUXT_DATA_PATH="E:/Code/cashbook/data"

NUXT_AUTH_SECRET="auth123"

NUXT_ADMIN_USERNAME="admin"
NUXT_ADMIN_PASSWORD="fb35e9343a1c095ce1c1d1eb6973dc570953159441c3ee315ecfefb6ed05f4cc"

# 超算平台 API Key - 从 https://www.scnet.cn/ui/llm/apikeys 获取
# deploy.sh 脚本会自动检测，如果为空会提示输入
NUXT_SUPERCOMPUTING_API_KEY=""
NUXT_SUPERCOMPUTING_MODEL="DeepSeek-R1-Distill-Qwen-7B"
# 语音记账专用模型（建议用支持 enable_thinking 的模型，例如 Qwen3 系列）
NUXT_SUPERCOMPUTING_VOICE_MODEL="DeepSeek-R1-Distill-Qwen-7B"

# 讯飞语音转文字（IAT）配置
# 从 https://console.xfyun.cn 创建应用后获取 APPID / APIKey / APISecret
NUXT_XUNFEI_APP_ID=""
NUXT_XUNFEI_API_KEY=""
NUXT_XUNFEI_API_SECRET=""
